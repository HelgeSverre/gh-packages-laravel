---
import Layout from '../../layouts/Layout.astro';
import {allPackages, buildDetail, type Package} from '../../lib/packages';

export async function getStaticPaths() {
    return allPackages.map((pkg) => ({
        params: {slug: pkg.name},
        props: {pkg},
    }));
}

const {pkg} = Astro.props as {pkg: Package};
const detail = await buildDetail(pkg);

function timeAgo(dateString: string): string {
    const now = new Date();
    const date = new Date(dateString);
    const seconds = Math.floor((now.getTime() - date.getTime()) / 1000);
    if (seconds < 60) return 'just now';
    if (seconds < 3600) return Math.floor(seconds / 60) + 'm ago';
    if (seconds < 86400) return Math.floor(seconds / 3600) + 'h ago';
    if (seconds < 604800) return Math.floor(seconds / 86400) + 'd ago';
    return date.toLocaleDateString();
}

const title = `${pkg.name} — Laravel Package Safari`;
const description = pkg.description || `Laravel package ${pkg.name}`;
---

<Layout title={title} description={description}>
    <header class="bg-yellow-300">
        <div class="max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8">
            <nav class="text-sm font-mono mb-4">
                <a
                        href={import.meta.env.BASE_URL || '/'}
                        class="text-zinc-700 hover:text-yellow-900 transition"
                >← All packages</a>
            </nav>
            <div class="flex flex-wrap items-start justify-between gap-4">
                <div class="min-w-0">
                    <h1 class="text-2xl sm:text-3xl font-bold text-zinc-900 break-words leading-tight">
                        {pkg.name}
                    </h1>
                    {pkg.description && (
                            <p class="mt-2 text-zinc-700 text-pretty">{pkg.description}</p>
                    )}
                </div>
                <a
                        href={pkg.url}
                        target="_blank"
                        rel="noopener"
                        class="shrink-0 inline-flex items-center gap-2 px-4 py-2 bg-zinc-900 text-white rounded-lg text-sm font-medium hover:bg-zinc-800 transition"
                >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    View on GitHub
                </a>
            </div>
            <div class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-sm text-zinc-700">
                <span class="inline-flex items-center gap-1">
                    <svg class="w-4 h-4 text-zinc-700" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    {pkg.stars.toLocaleString()} stars
                </span>
                {pkg.language && <span>{pkg.language}</span>}
                {pkg.license && <span>{pkg.license}</span>}
                <span>Updated {timeAgo(pkg.pushed_at)}</span>
            </div>
            {pkg.topics && pkg.topics.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1.5">
                        {pkg.topics.map((topic) => (
                                <span class="px-2 py-0.5 text-xs bg-yellow-200 text-yellow-900 rounded-full font-medium">
                                    {topic}
                                </span>
                        ))}
                    </div>
            )}
        </div>
    </header>

    <main class="flex-1 max-w-4xl mx-auto w-full px-4 py-8 sm:px-6 lg:px-8">
        {detail.readme_html ? (
                <article class="prose readme-prose max-w-none" set:html={detail.readme_html} />
        ) : (
                <div class="rounded-xl border border-dashed border-zinc-300 bg-white p-8 text-center">
                    <p class="text-zinc-600">
                        README not yet indexed for this package.
                    </p>
                    <p class="mt-2 text-sm text-zinc-500">
                        Check it directly on
                        <a href={pkg.url} target="_blank" rel="noopener" class="text-yellow-700 hover:underline">
                            GitHub
                        </a>.
                    </p>
                </div>
        )}
    </main>

    <footer class="bg-white border-t border-zinc-200 mt-auto">
        <div class="max-w-4xl mx-auto px-4 py-6 sm:px-6 lg:px-8 text-sm text-zinc-500">
            <a href={import.meta.env.BASE_URL || '/'} class="hover:text-zinc-900 transition">
                ← Back to package list
            </a>
        </div>
    </footer>
</Layout>
